        if MoMoConfig.AutoRift then
            pcall(function()
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                local maps = workspace:FindFirstChild("Maps")
                local rsMap = maps and maps:FindFirstChild("Reaper Society")
                local spawnedRifts = rsMap and rsMap:FindFirstChild("SpawnedRifts")
                local riftModel = spawnedRifts and spawnedRifts:FindFirstChild("RiftModel")

                if riftModel then
                    local targetPart = riftModel:IsA("Model") and riftModel.PrimaryPart or riftModel:FindFirstChildWhichIsA("BasePart") or riftModel
                    if targetPart and targetPart:IsA("BasePart") then
                        local distToRift = (hrp.Position - targetPart.Position).Magnitude
                        
                        if distToRift > 1000 then 
                            local rsRemote = game:GetService("ReplicatedStorage"):FindFirstChild("ByteNetReliable")
                            if rsRemote then rsRemote:FireServer(unpack({buffer.fromstring("\005\014\000Reaper Society\004\014\000Reaper Society")})) end
                            task.wait(2.5)
                        elseif distToRift > 15 then
                            hrp.CFrame = targetPart.CFrame + Vector3.new(0, 3, 0)
                            task.wait(0.2)
                        else
                            local prompt = riftModel:FindFirstChildWhichIsA("ProximityPrompt", true)
                            if prompt then pcall(function() fireproximityprompt(prompt) end) end
                            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                            task.wait(0.1)
                            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                            task.wait(0.2)
                        end
                    end
                end
            end)
        end
    end
end)

-- ==========================================
-- ฟังก์ชันค้นหามอนสเตอร์สำหรับ Rift
-- ==========================================
local function GetClosestRiftTarget_Server()
    local worlds = workspace:FindFirstChild("Worlds")
    local clientsFolder = worlds and worlds:FindFirstChild("Targets") and worlds.Targets:FindFirstChild("Clients")
    local serverFolder = worlds and worlds:FindFirstChild("Targets") and worlds.Targets:FindFirstChild("Server")
    
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not clientsFolder or not serverFolder then return nil, nil end

    local closestServerMob = nil
    local closestHrp = nil
    local shortestDistance = math.huge

    for _, serverMob in pairs(serverFolder:GetChildren()) do
        local lowerName = string.lower(serverMob.Name)
        if string.find(lowerName, "rifts") then
            local serverHum = serverMob:FindFirstChild("Humanoid")
            if serverHum and serverHum.Health > 0 then
                local mobHrp = serverMob:FindFirstChild("HumanoidRootPart")
                if not mobHrp then
                    for _, clientMob in pairs(clientsFolder:GetChildren()) do
                        if string.find(string.lower(clientMob.Name), "rifts") then
                            mobHrp = clientMob:FindFirstChild("HumanoidRootPart")
                            if mobHrp then break end
                        end
                    end
                end
                if mobHrp then
                    local dist = (hrp.Position - mobHrp.Position).Magnitude
                    if dist < shortestDistance then
                        shortestDistance = dist
                        closestServerMob = serverMob 
                        closestHrp = mobHrp
                    end
                end
            end
        end
    end
    return closestServerMob, closestHrp
end

