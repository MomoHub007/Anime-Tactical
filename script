    end
    
    pcall(function()
        local invUnits = game:GetService("ReplicatedStorage").Players_Data[player.Name].Inventory.Units
        for i, u in ipairs(invUnits:GetChildren()) do
            -- เช็คว่ามี Nickname ไหม ถ้ามีและไม่ว่างเปล่าให้ใช้ Nickname ถ้าไม่มีให้ใช้ชื่อเดิม
