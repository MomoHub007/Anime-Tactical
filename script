-- ฟังก์ชัน Auto Clear Rift 
-- ==========================================
task.spawn(function()
    while task.wait(0.01) do
        if MoMoConfig.AutoClearRift then
            pcall(function()
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                local targetServerMob, targetHrp = GetClosestRiftTarget_Server()
                
                if targetServerMob and targetHrp then
                    local serverHum = targetServerMob:FindFirstChild("Humanoid")
                    if serverHum and serverHum.Health > 0 then
                        -- วาร์ปไปหามอนครั้งเดียว
                        local freshChar = player.Character
                        local freshHrp = freshChar and freshChar:FindFirstChild("HumanoidRootPart")
                        if freshHrp then
                            freshHrp.CFrame = CFrame.new(targetHrp.Position + Vector3.new(0, 3, 0))
                        end
                        -- รอจนมอนตาย
                        repeat
                            task.wait(0.1) 
                            if not targetServerMob or not targetServerMob.Parent then break end
                            if not targetHrp or not targetHrp.Parent then break end
                            if not MoMoConfig.AutoClearRift then break end
                        until serverHum.Health <= 0
                    end
                end
            end)
        end
    end
end)

