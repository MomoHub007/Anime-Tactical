-- ==========================================
-- Search and Tween Loop for Normal Farm
-- ==========================================
local function GetClosestServerTarget()
    local worlds = workspace:FindFirstChild("Worlds")
    if not worlds then return nil end
    local targets = worlds:FindFirstChild("Targets")
    if not targets then return nil end
    local serverFolder = targets:FindFirstChild("Server")
    if not serverFolder then return nil end

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local closestModel = nil
    local shortestDistance = math.huge

    for _, serverModel in pairs(serverFolder:GetChildren()) do
        if serverModel:IsA("Model") then
            local hum = serverModel:FindFirstChild("Humanoid")
            local mobHrp = serverModel:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and mobHrp then
                local isValid = false
                
                if MoMoConfig.FarmMode == "Near Monster" then
                    isValid = true
                elseif MoMoConfig.FarmMode == "Select Target" then
                    for _, desc in pairs(serverModel:GetDescendants()) do
                        if desc.Name == "Names" and desc:IsA("TextLabel") then
                            if type(AutoTweenTarget) == "table" then
                                if table.find(AutoTweenTarget, desc.Text) or AutoTweenTarget[desc.Text] then
                                    isValid = true
                                    break
                                end
                            elseif type(AutoTweenTarget) == "string" then
                                if AutoTweenTarget == desc.Text then
                                    isValid = true
                                    break
                                end
                            end
                        end
                    end
                end
                
                if isValid then
                    local dist = (hrp.Position - mobHrp.Position).Magnitude
                    if dist < shortestDistance then
                        shortestDistance = dist
                        closestModel = serverModel
                    end
                end
            end
        end
    end
    return closestModel
end

task.spawn(function()
    while task.wait(0.01) do 
        local isBossPriorityActive = MoMoConfig.AutoBossFight and IsBossSpawned()
        
        if MoMoConfig.AutoTween and not MoMoConfig.AutoRaid and not MoMoConfig.AutoClearRaid and not MoMoConfig.AutoTower and not isBossPriorityActive then 
            pcall(function()
                local targetModel = GetClosestServerTarget()
                if targetModel then
                    local mobHrp = targetModel:FindFirstChild("HumanoidRootPart")
                    local hum = targetModel:FindFirstChild("Humanoid")
                    local char = player.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    
                    if hrp and mobHrp and hum then
                        local req = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                        local gameplayReq = req and req:FindFirstChild("Gameplays") and req.Gameplays:FindFirstChild("Request")
                        
                        local lastHealth = hum.Health
                        local stuckTimer = 0
                        local hasFired = false
                        
                        repeat
                            task.wait(0.01)
                            if not targetModel or not targetModel.Parent or not targetModel:FindFirstChild("HumanoidRootPart") then break end
                            if not MoMoConfig.AutoTween or MoMoConfig.AutoRaid or MoMoConfig.AutoClearRaid or MoMoConfig.AutoTower or (MoMoConfig.AutoBossFight and IsBossSpawned()) then break end
                            
                            local dist = (hrp.Position - mobHrp.Position).Magnitude
                            if dist > 100 then
                                local standPos = (mobHrp.CFrame * CFrame.new(0, 0, -4)).Position
                                TweenService:Create(hrp, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {CFrame = CFrame.lookAt(standPos, mobHrp.Position)}):Play()
                                hasFired = false 
                            else
                                if not hasFired then
                                    if gameplayReq then gameplayReq:FireServer(targetModel.Name, "Mouse") end
                                    hasFired = true
                                    lastHealth = hum.Health
                                    stuckTimer = 0
                                else
                                    stuckTimer = stuckTimer + 0.01
                                    if hum.Health < lastHealth then
                                        lastHealth = hum.Health
                                        stuckTimer = 0
                                    end
                                    if stuckTimer >= 1 then
                                        if gameplayReq then gameplayReq:FireServer(targetModel.Name, "Mouse") end
                                        stuckTimer = 0 
                                    end
                                end
                            end
                        until hum.Health <= 0
                    end
                end
            end)
        end
    end
end)

