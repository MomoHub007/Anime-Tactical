-- ==========================================
task.spawn(function()
    while task.wait(0.1) do
        if MoMoConfig.AutoRollTrait and MoMoConfig.RollTraitUnitName ~= "" then
            pcall(function()
                local charData = game:GetService("ReplicatedStorage"):FindFirstChild("Players_Data")
                if not charData then return end
                local targetUnit = charData[player.Name].Inventory.Units:FindFirstChild(MoMoConfig.RollTraitUnitName)
                if not targetUnit then return end

                local traitValueObj = targetUnit:FindFirstChild(MoMoConfig.RollTraitSlot .. "_Trait")
                if not traitValueObj then return end

                local currentValue = traitValueObj.Value
                local gotWantedTrait = false
                if type(MoMoConfig.RollTargetTraits) == "table" then
                    for _, wanted in pairs(MoMoConfig.RollTargetTraits) do
                        if currentValue == wanted then gotWantedTrait = true; break end
                    end
                end

                if gotWantedTrait then
                    MoMoConfig.AutoRollTrait = false 
                    if shared.MoMoWindow then shared.MoMoWindow:Notify({Title = "🎉 Trait Rolled!", Desc = "Successfully rolled: " .. currentValue, Time = 10}) end
                    return
                end

                local serverArgsTraits = {}
                if type(MoMoConfig.RollTargetTraits) == "table" then
                    for _, trait in pairs(MoMoConfig.RollTargetTraits) do
                        local baseName = string.split(trait, "_")[1]
                        if not table.find(serverArgsTraits, baseName) then table.insert(serverArgsTraits, baseName) end
                    end
                end

                local args = {MoMoConfig.RollTraitUnitName, MoMoConfig.RollTraitSlot, serverArgsTraits, false}
                game:GetService("ReplicatedStorage").Remotes.Gamblings.Traits:FireServer(unpack(args))
                task.wait(MoMoConfig.RollTraitDelay)
            end)
        else
            task.wait(1)
        end
    end
end)

