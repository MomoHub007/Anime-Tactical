-- ==========================================
local function IsRiftActive()
    if not MoMoConfig.AutoRift then return false end
    
    local maps = workspace:FindFirstChild("Maps")
    local rsMap = maps and maps:FindFirstChild("Reaper Society")
    local spawned = rsMap and rsMap:FindFirstChild("SpawnedRifts")
    local hasPillar = spawned and spawned:FindFirstChild("RiftModel") ~= nil
    
    local worlds = workspace:FindFirstChild("Worlds")
    local clientsFolder = worlds and worlds:FindFirstChild("Targets") and worlds.Targets:FindFirstChild("Clients")
    local hasMobs = false
    if clientsFolder then
        for _, mob in pairs(clientsFolder:GetChildren()) do
            if string.find(mob.Name, "Rifts") then hasMobs = true; break end
        end
    end

    local inRiftDungeon = false
    local raidsVisual = workspace:FindFirstChild("Raids_Visual")
    if raidsVisual then
        for _, folder in pairs(raidsVisual:GetChildren()) do
            if string.find(folder.Name, "Reaper Society_Rift_") then
                inRiftDungeon = true
                break
            end
        end
    end
    
    return hasPillar or hasMobs or inRiftDungeon
end

local function IsBossSpawned()
    local bossVisual = workspace:FindFirstChild("BossFights_Visual")
    if not bossVisual then return false end
    
    local demonForest = bossVisual:FindFirstChild("Demon Forest")
    local configs = demonForest and demonForest:FindFirstChild("Configs")
    local others = configs and configs:FindFirstChild("Others")
    local enemiesObj = others and others:FindFirstChild("Enemies")
    
    if enemiesObj then
        -- แก้บัคอ่านค่า "1/1" อย่างเด็ดขาด
        local valString = tostring(enemiesObj.Value)
        local num = tonumber(string.split(valString, "/")[1])
        if num and num > 0 then
            return true
        end
    end
    return false
end

local function IsBossActive()
    if not MoMoConfig.AutoBossFight then return false end
    return IsBossSpawned()
end

local function IsInRaid()
    local serverRaidName = MoMoConfig.RaidMap .. "_Server_" .. player.Name
    local clientRaidName = MoMoConfig.RaidMap .. "_Clients_" .. player.Name
    local raidsVisual = workspace:FindFirstChild("Raids_Visual")
    
    if raidsVisual and (raidsVisual:FindFirstChild(serverRaidName) or raidsVisual:FindFirstChild(clientRaidName)) then
        return true
    end
    return false
end

local function IsRaidActive()
    if not MoMoConfig.AutoRaid then return false end
    return IsInRaid()
end

