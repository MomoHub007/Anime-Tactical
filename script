            pcall(function()
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                -- [บล็อก Priority] ถ้าเสาเกิด หรือบอสเกิด ให้วาร์ปกลับ Lobby เพื่อหลบไปทำของสำคัญก่อน
                if IsRiftActive() or IsBossActive() then    
                    if IsInRaid() and not isEscapingRaid then
                        isEscapingRaid = true
                        local rs = game:GetService("ReplicatedStorage"):FindFirstChild("ByteNetReliable")
                        if rs then rs:FireServer(unpack({buffer.fromstring("\005\005\000Lobby\004\005\000Lobby")})) end
                        task.wait(2.5)
                        isEscapingRaid = false
                    end
                    return 
                end

                local serverRaidName = MoMoConfig.RaidMap .. "_Server_" .. player.Name
                local clientRaidName = MoMoConfig.RaidMap .. "_Clients_" .. player.Name
                local serverRaid = workspace:FindFirstChild("Raids_Visual") and workspace.Raids_Visual:FindFirstChild(serverRaidName)
                local clientRaid = workspace:FindFirstChild("Raids_Visual") and workspace.Raids_Visual:FindFirstChild(clientRaidName)

                local enemiesValObj = serverRaid and serverRaid:FindFirstChild("Configs") and serverRaid.Configs:FindFirstChild("Others") and serverRaid.Configs.Others:FindFirstChild("Enemies")
                
                -- ซ่อมบัค tonumber() ทะลวง string "1/1" ของ Raid แบบ 100%
                local valString = enemiesValObj and tostring(enemiesValObj.Value) or "0"
                local currentEnemies = tonumber(string.split(valString, "/")[1]) or 0

                local targetMob = GetClosestRaidTarget_Clients()
                local clientsFolder = workspace:FindFirstChild("Worlds") and workspace.Worlds:FindFirstChild("Targets") and workspace.Worlds.Targets:FindFirstChild("Clients")

                -- ระบบแก้มอนสเตอร์หาย: เช็ค 2 รอบก่อน แล้วค่อยวาร์ปหา Phase Unlockers
                if not targetMob and currentEnemies > 0 then

                    -- รอบที่ 1
                    task.wait(1)
                    targetMob = GetClosestRaidTarget_Clients()

                    -- รอบที่ 2
                    if not targetMob then
                        task.wait(1)
                        targetMob = GetClosestRaidTarget_Clients()
                    end

                    -- ยังไม่เจอหลังเช็ค 2 รอบ → วาร์ปหา Unlockers ทีละ Phase
                    if not targetMob then
                        if clientRaid and clientRaid:FindFirstChild("Configs") then
                            if MoMoConfig.RaidMap == "Double Dungeons" then
                                -- Double Dungeons ใช้ Spawn point เดิม
                                local spawnPoint = clientRaid.Configs:FindFirstChild("Others") and clientRaid.Configs.Others:FindFirstChild("Spawn")
                                if spawnPoint then
                                    local tPart = spawnPoint:IsA("Model") and spawnPoint.PrimaryPart or spawnPoint:FindFirstChildWhichIsA("BasePart") or spawnPoint
                                    if tPart and tPart:IsA("BasePart") then
                                        hrp.CFrame = CFrame.new(tPart.Position + Vector3.new(0, 4, 5))
                                    end
                                end
                            else
                                -- วาร์ปไปยัง Unlockers ของแต่ละ Phase ทีละตัว
                                local foundMob = false
                                for i = 1, 10 do
                                    if foundMob then break end
                                    local phaseFolder = clientRaid.Configs:FindFirstChild("Phase" .. tostring(i))
                                    if phaseFolder then
                                        local unlockers = phaseFolder:FindFirstChild("Unlockers")
                                        if unlockers then
                                            local unlockerList = unlockers:GetChildren()
                                            for _, unlocker in ipairs(unlockerList) do
                                                if foundMob then break end
                                                -- วาร์ปไปที่ Unlocker แต่ละชิ้น
                                                local targetPart = unlocker:IsA("BasePart") and unlocker
                                                    or (unlocker:IsA("Model") and (unlocker.PrimaryPart or unlocker:FindFirstChildWhichIsA("BasePart")))
                                                    or unlocker:FindFirstChildWhichIsA("BasePart")
                                                if targetPart and targetPart:IsA("BasePart") then
                                                    hrp.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 4, 4))
                                                    task.wait(0.5)
                                                    -- เช็คว่าเจอมอนหลังวาร์ปแต่ละจุดไหม
                                                    if clientsFolder then
                                                        for _, checkMob in pairs(clientsFolder:GetChildren()) do
                                                            if string.find(checkMob.Name, "Raids") then
                                                                foundMob = true; break
                                                            end
                                                        end
                                                    end
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                        task.wait(0.5)
                        return
                    end
                end

                if targetMob then
                    local mobHrp = targetMob:FindFirstChild("HumanoidRootPart")
                    local serverFolder = workspace:FindFirstChild("Worlds") and workspace.Worlds:FindFirstChild("Targets") and workspace.Worlds.Targets:FindFirstChild("Server")
                    local serverMob = serverFolder and serverFolder:FindFirstChild(targetMob.Name)
                    local serverHum = serverMob and serverMob:FindFirstChild("Humanoid")
                    
                    if mobHrp and serverHum and serverHum.Health > 0 then
                        local lastKnownHp = serverHum.Health
                        local stuckTimer = 0

                        -- วาร์ปครั้งแรก
                        local freshChar = player.Character
                        local freshHrp = freshChar and freshChar:FindFirstChild("HumanoidRootPart")
                        if freshHrp then
                            freshHrp.CFrame = CFrame.new(mobHrp.Position + Vector3.new(0, 4, 5))
                        end

                        repeat
                            task.wait(0.5)
                            if not targetMob or not targetMob.Parent then break end
                            if not serverMob or not serverMob.Parent then break end
                            if not MoMoConfig.AutoClearRaid or IsRiftActive() or IsBossActive() then break end

                            -- เช็คเลือดฝั่ง Server
                            if serverHum.Health < lastKnownHp then
                                -- เลือดลดแล้ว รีเซ็ต timer
                                lastKnownHp = serverHum.Health
                                stuckTimer = 0
                            else
                                stuckTimer = stuckTimer + 0.1
                                -- เลือดไม่ลดนาน 1.5 วิ → วาร์ปซ้ำ
                                if stuckTimer >= 1.5 then
                                    stuckTimer = 0
                                    lastKnownHp = serverHum.Health
                                    local fc = player.Character
                                    local fh = fc and fc:FindFirstChild("HumanoidRootPart")
                                    local fm = targetMob:FindFirstChild("HumanoidRootPart")
                                    if fh and fm then
                                        fh.CFrame = CFrame.new(fm.Position + Vector3.new(0, 4, 5))
                                    end
                                end
                            end
                        until serverHum.Health <= 0
                    end
                end
            end)
        end
    end
end)

