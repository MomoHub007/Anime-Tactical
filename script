                -- ==============================
                local bossVisual = workspace:FindFirstChild("BossFights_Visual")
                local demonForestVisual = bossVisual and bossVisual:FindFirstChild("Demon Forest")
                local enemiesObj = demonForestVisual
                    and demonForestVisual:FindFirstChild("Configs")
                    and demonForestVisual.Configs:FindFirstChild("Others")
                    and demonForestVisual.Configs.Others:FindFirstChild("Enemies")

                if not enemiesObj then return end

                local valString = tostring(enemiesObj.Value)
                local enemyCount = tonumber(string.split(valString, "/")[1]) or 0

                if enemyCount <= 0 then return end -- บอสยังไม่เกิด

                -- ==============================
                -- STEP 2: Fire ไป Demon Forest แล้วรอ 3 วิ
                -- ==============================
                local rs = game:GetService("ReplicatedStorage"):WaitForChild("ByteNetReliable")
                if rs then
                    rs:FireServer(unpack({
                        buffer.fromstring("\005\f\000Demon Forest\004\f\000Demon Forest")
                    }))
                end
                task.wait(3)

                -- รีเฟรช char/hrp หลังวาร์ป
                char = player.Character
                hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                -- ==============================
                -- STEP 3: วาร์ปไปที่ BossFight_Entering["Demon Forest"] แล้วรอ 2 วิ
                -- ==============================
                local bossEntering = workspace:FindFirstChild("BossFight_Entering")
                    or workspace:FindFirstChild("BossFights_Entering")
                local dfEntering = bossEntering and bossEntering:FindFirstChild("Demon Forest")

                if not dfEntering then return end

                local enterPart = dfEntering:IsA("BasePart") and dfEntering
                    or (dfEntering:IsA("Model") and (dfEntering.PrimaryPart or dfEntering:FindFirstChildWhichIsA("BasePart")))
                    or dfEntering:FindFirstChildWhichIsA("BasePart")

                if enterPart then
                    hrp.CFrame = CFrame.new(enterPart.Position + Vector3.new(0, 4, 4))
                end
                task.wait(2)

                -- รีเฟรช char/hrp อีกครั้ง
                char = player.Character
                hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                -- ==============================
                -- STEP 4: หาและตีบอส พร้อมเช็คเลือด Server
                -- ==============================
                local function GetBossTarget()
                    local serverFolder = workspace:FindFirstChild("Worlds")
                        and workspace.Worlds:FindFirstChild("Targets")
                        and workspace.Worlds.Targets:FindFirstChild("Server")
                    local clientsFolder2 = workspace:FindFirstChild("Worlds")
                        and workspace.Worlds:FindFirstChild("Targets")
                        and workspace.Worlds.Targets:FindFirstChild("Clients")

                    if not serverFolder then return nil, nil end

                    for _, serverMob in pairs(serverFolder:GetChildren()) do
                        local lowerName = string.lower(serverMob.Name)
                        if string.find(lowerName, "bossfight") or string.find(lowerName, "kokushibo") then
                            local serverHum = serverMob:FindFirstChild("Humanoid")
                            if serverHum and serverHum.Health > 0 then
                                local mobHrp = serverMob:FindFirstChild("HumanoidRootPart")
                                if not mobHrp and clientsFolder2 then
                                    for _, cMob in pairs(clientsFolder2:GetChildren()) do
                                        local cLower = string.lower(cMob.Name)
                                        if string.find(cLower, "bossfight") or string.find(cLower, "kokushibo") then
                                            mobHrp = cMob:FindFirstChild("HumanoidRootPart")
                                            if mobHrp then break end
                                        end
                                    end
                                end
                                return serverMob, mobHrp
                            end
                        end
                    end
                    return nil, nil
                end

                local clearAttempts = 0
                repeat
                    clearAttempts = clearAttempts + 1
                    local bossServerMob, bossHrp = GetBossTarget()

                    if bossServerMob and bossHrp then
                        local bossHum = bossServerMob:FindFirstChild("Humanoid")
                        local lastKnownHp = bossHum and bossHum.Health or 0
                        local stuckTimer = 0

                        -- วาร์ปไปหาบอสครั้งแรก
                        char = player.Character
                        hrp = char and char:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local freshBossHrp = bossServerMob:FindFirstChild("HumanoidRootPart") or bossHrp
                            hrp.CFrame = CFrame.new(freshBossHrp.Position + Vector3.new(0, 4, 4))
                        end

                        -- รอจนบอสตาย พร้อมเช็คเลือด Server
                        repeat
                            task.wait(0.5)
                            if not bossServerMob or not bossServerMob.Parent then break end
                            if not bossHum or not bossHum.Parent or bossHum.Health <= 0 then break end
                            if not MoMoConfig.AutoBossFight or IsRiftActive() then break end

                            if bossHum.Health < lastKnownHp then
                                -- เลือดลดปกติ รีเซ็ต timer
                                lastKnownHp = bossHum.Health
                                stuckTimer = 0
                            else
                                stuckTimer = stuckTimer + 0.1
                                -- เลือดไม่ลดนาน 1.5 วิ → วาร์ปซ้ำ
                                if stuckTimer >= 1.5 then
                                    stuckTimer = 0
                                    lastKnownHp = bossHum.Health
                                    char = player.Character
                                    hrp = char and char:FindFirstChild("HumanoidRootPart")
                                    local freshBossHrp = bossServerMob:FindFirstChild("HumanoidRootPart") or bossHrp
                                    if hrp and freshBossHrp then
                                        hrp.CFrame = CFrame.new(freshBossHrp.Position + Vector3.new(0, 4, 4))
                                    end
                                end
                            end
                        until not bossHum or bossHum.Health <= 0
                    else
                        task.wait(1)
                    end

                    local checkBoss, _ = GetBossTarget()
                    if not checkBoss then break end

                until clearAttempts >= 30 or not MoMoConfig.AutoBossFight

            end)
        end
    end
end)
