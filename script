                    local serverFolder = workspace:FindFirstChild("Worlds") and workspace.Worlds:FindFirstChild("Targets") and workspace.Worlds.Targets:FindFirstChild("Server")
                    local serverMob = serverFolder and serverFolder:FindFirstChild(targetMob.Name)
                    local serverHum = serverMob and serverMob:FindFirstChild("Humanoid")
                    
                    if mobHrp and serverHum then
                        local req = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                        local gameplayReq = req and req:FindFirstChild("Gameplays") and req.Gameplays:FindFirstChild("Request")
                        
                        local lastHealth = serverHum.Health
                        local stuckCombatTimer = 0
                        local hasFired = false
                        
                        repeat
                            task.wait(0.1)
                            if not targetMob or not targetMob.Parent or not targetMob:FindFirstChild("HumanoidRootPart") then break end
                            if not serverMob or not serverMob.Parent or not serverMob:FindFirstChild("Humanoid") then break end
                            if not MoMoConfig.AutoClearRaid then break end
                            
                            local dist = (hrp.Position - mobHrp.Position).Magnitude
                            
                            if dist > 100 then
                                local standPos = (mobHrp.CFrame * CFrame.new(0, 0, 4)).Position
                                TweenService:Create(hrp, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {CFrame = CFrame.lookAt(standPos, mobHrp.Position)}):Play()
                                hasFired = false 
                            else
                                if not hasFired then
                                    if gameplayReq then gameplayReq:FireServer(targetMob.Name, "Mouse") end
                                    hasFired = true
                                    lastHealth = serverHum.Health
                                    stuckCombatTimer = 0
                                else
                                    stuckCombatTimer = stuckCombatTimer + 0.1
                                    if serverHum.Health < lastHealth then
                                        lastHealth = serverHum.Health
                                        stuckCombatTimer = 0
                                    end
                                    if stuckCombatTimer >= 1 then
                                        if gameplayReq then gameplayReq:FireServer(targetMob.Name, "Mouse") end
                                        stuckCombatTimer = 0 
                                    end
                                end
                            end
                        until serverHum.Health <= 0
                    end
                end
            end)
        end
    end
end)

