-- =============================================================
-- MomoHub - Auto Roll Trait + Notification Status Fix
-- =============================================================

local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local VirtualInputManager = game:GetService("VirtualInputManager")
local UserInputService = game:GetService("UserInputService")

-- ==========================================
-- Config Management Logic
-- ==========================================
local ConfigFolder = "MoMoHub_Data"
local ConfigFile = ConfigFolder .. "/TraitSettings.json" 

local DefaultConfig = {
    AntiAFK = false,
    AutoSave = false,
    AutoLoad = false,
    AutoRollTrait = false,
    RollUnitName = "",
    RollTraitSlot = "Primary",
    RollTargetTraits = {},
    RollDelay = 0.5
}

local MoMoConfig = {}
if isfolder and not isfolder(ConfigFolder) then makefolder(ConfigFolder) end

local function LoadConfig()
    if isfile and isfile(ConfigFile) then
        local success, decoded = pcall(function() return HttpService:JSONDecode(readfile(ConfigFile)) end)
        if success and type(decoded) == "table" then
            for k, v in pairs(DefaultConfig) do
                if decoded[k] == nil then decoded[k] = v end
            end
            return decoded
        end
    end
    return DefaultConfig
end

local SavedData = LoadConfig()
if SavedData.AutoLoad then
    MoMoConfig = SavedData
else
    MoMoConfig = DefaultConfig
    MoMoConfig.AutoLoad = SavedData.AutoLoad 
    MoMoConfig.AutoSave = SavedData.AutoSave 
end

local function SaveConfig()
    if writefile then pcall(function() writefile(ConfigFile, HttpService:JSONEncode(MoMoConfig)) end) end
end
local function CheckAndSave() if MoMoConfig.AutoSave then SaveConfig() end end

local player = Players.LocalPlayer

-- ==========================================
-- Start Loading UI (X2ZU)
-- ==========================================
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/x2zu/OPEN-SOURCE-UI-ROBLOX/refs/heads/main/X2ZU%20UI%20ROBLOX%20OPEN%20SOURCE/DummyUi-leak-by-x2zu/fetching-main/Tools/Framework.luau"))()

local Window = Library:Window({
    Title = "MoMoHub (Trait Only)", Desc = "Auto Roll Trait System",
    Icon = "sparkles", Theme = "Amethyst", Color = Color3.fromRGB(170, 0, 255), 
    Config = {Keybind = Enum.KeyCode.LeftControl, Size = UDim2.new(0, 500, 0, 480)},
    CloseUIButton = {Enabled = false, Text = ""}
})
shared.MoMoWindow = Window 

-- ==========================================
-- Draggable UI Toggle Button System (Mobile)
-- ==========================================
do
    local CoreGui = game:GetService("CoreGui")
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "HubMobileToggle"
    ScreenGui.ResetOnSpawn = false
    local success, _ = pcall(function() ScreenGui.Parent = CoreGui end)
    if not success then ScreenGui.Parent = player:WaitForChild("PlayerGui") end

    local ToggleBtn = Instance.new("ImageButton")
    ToggleBtn.Name = "ToggleBtn"
    ToggleBtn.Parent = ScreenGui
    ToggleBtn.BackgroundTransparency = 1 
    ToggleBtn.Position = UDim2.new(0.5, -30, 0.1, 0) 
    ToggleBtn.Size = UDim2.new(0, 60, 0, 60) 
    ToggleBtn.Image = "rbxthumb://type=Asset&id=82100122245666&w=150&h=150"

    local dragging, dragStart, startPos, clickTime = false, nil, nil, 0

    ToggleBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = ToggleBtn.Position
            clickTime = tick() 
        end
    end)

    ToggleBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            if tick() - clickTime < 0.2 then
                pcall(function()
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftControl, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
                end)
            end
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            ToggleBtn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ==========================================
-- ฟังก์ชันสำหรับเช็คและแจ้งเตือน Trait
-- ==========================================
local function CheckAndNotifyTrait(unitName)
    if unitName == "" or unitName == "No Units Found" then return end
    pcall(function()
        local charData = game:GetService("ReplicatedStorage"):FindFirstChild("Players_Data")
        if charData and charData:FindFirstChild(player.Name) then
            local targetUnit = charData[player.Name].Inventory.Units:FindFirstChild(unitName)
            if targetUnit then
                local pTrait = targetUnit:FindFirstChild("Primary_Trait")
                local sTrait = targetUnit:FindFirstChild("Sub_Trait")
                
                local pVal = pTrait and pTrait.Value or "ไม่มี"
                local sVal = sTrait and sTrait.Value or "ไม่มี"
                
                if shared.MoMoWindow then
                    shared.MoMoWindow:Notify({
                        Title = "🔍 Status: " .. unitName, 
                        Desc = "Primary: " .. pVal .. "\nSub: " .. sVal, 
                        Time = 5
                    })
                end
            end
        end
    end)
end

