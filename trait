Window:Line()

-- ==========================================
-- Tab 2: Settings (Anti-AFK & Data)
-- ==========================================
local SettingsTab = Window:Tab({Title = "Settings", Icon = "wrench"})
local AntiAfkConnection

SettingsTab:Section({Title = "Utility"})
SettingsTab:Toggle({
    Title = "Anti-AFK", 
    Desc = "ป้องกันเกมเตะเมื่อปล่อยจอทิ้งไว้นานๆ",
    Value = MoMoConfig.AntiAFK,
    Callback = function(State)
        MoMoConfig.AntiAFK = State; CheckAndSave()
        if State then
            AntiAfkConnection = player.Idled:Connect(function()
                VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
                task.wait(1)
                VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            end)
        else
            if AntiAfkConnection then AntiAfkConnection:Disconnect(); AntiAfkConnection = nil end
        end
    end
})

SettingsTab:Section({Title = "Data Settings"})
SettingsTab:Toggle({Title = "Auto Save Config", Value = MoMoConfig.AutoSave, Callback = function(State) MoMoConfig.AutoSave = State; SaveConfig() end})
SettingsTab:Toggle({Title = "Auto Load Config", Value = MoMoConfig.AutoLoad, Callback = function(State) MoMoConfig.AutoLoad = State; SaveConfig() end})

Window:Notify({Title = "MoMoHub", Desc = "Loaded Successfully!", Time = 3})

-- ==========================================
-- Background Loop: Auto Roll Trait
-- ==========================================
task.spawn(function()
    while task.wait(0.1) do
        if MoMoConfig.AutoRollTrait and MoMoConfig.RollUnitName ~= "" then
            pcall(function()
                local charData = game:GetService("ReplicatedStorage"):FindFirstChild("Players_Data")
                if not charData then return end
                local pFolder = charData:FindFirstChild(player.Name)
                if not pFolder then return end
                local targetUnit = pFolder.Inventory.Units:FindFirstChild(MoMoConfig.RollUnitName)
                if not targetUnit then return end

                local targetTraitName = MoMoConfig.RollTraitSlot .. "_Trait"
                local traitValueObj = targetUnit:FindFirstChild(targetTraitName)
                if not traitValueObj then return end

                local currentValue = traitValueObj.Value

                -- ตรวจสอบว่าตรงกับเป้าหมายหรือไม่
                local gotWantedTrait = false
                if type(MoMoConfig.RollTargetTraits) == "table" then
                    for _, wanted in pairs(MoMoConfig.RollTargetTraits) do
                        if currentValue == wanted then
                            gotWantedTrait = true
                            break
                        end
                    end
                end

                if gotWantedTrait then
                    MoMoConfig.AutoRollTrait = false 
                    if shared.MoMoWindow then
                        shared.MoMoWindow:Notify({Title = "🎉 Trait Rolled!", Desc = "เป้าหมายสำเร็จ! ได้รับ: " .. currentValue, Time = 10})
                    end
                    return
                end

                -- แปลงชื่อ Trait
                local serverArgsTraits = {}
                if type(MoMoConfig.RollTargetTraits) == "table" then
                    for _, trait in pairs(MoMoConfig.RollTargetTraits) do
                        local baseName = string.split(trait, "_")[1]
                        if not table.find(serverArgsTraits, baseName) then
                            table.insert(serverArgsTraits, baseName)
                        end
                    end
                end

                -- ส่งคำสั่ง Roll
                local args = {
                    MoMoConfig.RollUnitName,
                    MoMoConfig.RollTraitSlot,
                    serverArgsTraits,
                    false
                }
                
                game:GetService("ReplicatedStorage").Remotes.Gamblings.Traits:FireServer(unpack(args))
                
                -- หน่วงเวลา
                task.wait(MoMoConfig.RollDelay)
            end)
        else
            task.wait(1)
        end
    end
end)
